# For Vite (this project)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Resend (email delivery — set on Vercel, not locally)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Groq (AI chatbot & daily email copywriting — set on Vercel, not locally)
# Get free key at https://console.groq.com
# GROQ_API_KEY=gsk_xxxxxxxxxxxx
# VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxx  # Same key, compiled into JS bundle for browser fallback

# Supabase service role key (for admin/cron operations that bypass RLS)
# Found in Supabase Dashboard → Project Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Cron secret (optional — extra protection for /api/cron/* endpoints)
# CRON_SECRET=your-secret-here

# Custom site URL (set this to your domain on Vercel to fix verification links)
# SITE_URL=https://pinkmanx.vip
